{
  "name": "deutsch-lernen",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "vite build",
    "check:all": "bun run typecheck && bun run format:check && bun run lint:all",
    "dev": "vite",
    "doctor": "bunx react-doctor@latest",
    "fix:all": "bun run format && bun run lint --fix && bun run lint:css:fix && bun run lint:md:fix",
    "format": "prettier --write \"**/*.{js,ts,tsx,css,json,md}\"",
    "format:check": "prettier --check \"**/*.{js,ts,tsx,css,json,md}\"",
    "preinstall": "npx only-allow bun",
    "lint": "eslint .",
    "lint:all": "bun run lint && bun run lint:css && bun run lint:md",
    "lint:css": "stylelint \"**/*.css\"",
    "lint:css:fix": "stylelint \"**/*.css\" --fix",
    "lint:md": "markdownlint \"**/*.md\" --ignore \"node_modules\"",
    "lint:md:fix": "markdownlint \"**/*.md\" --ignore \"node_modules\" --fix",
    "start": "vite preview",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@gsap/react": "^2.1.2",
    "@tanstack/react-router": "^1.170.18",
    "@tanstack/react-start": "^1.168.32",
    "@tanstack/router-plugin": "^1.168.23",
    "@vitejs/plugin-react": "^6.0.3",
    "clsx": "^2.1.1",
    "gsap": "^3.15.0",
    "lucide-react": "^1.25.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "tailwind-merge": "^3.6.0",
    "vite": "^8.1.5"
  },
  "devDependencies": {
    "@dreamsicle.io/stylelint-config-tailwindcss": "^1.2.2",
    "@eslint/compat": "^2.1.0",
    "@eslint/markdown": "^8.0.3",
    "@ianvs/prettier-plugin-sort-imports": "^4.7.1",
    "@tailwindcss/vite": "^4.3.3",
    "@types/eslint-plugin-security": "^3.0.1",
    "@types/node": "^26.1.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/eslint-plugin": "^8.65.0",
    "@typescript-eslint/parser": "^8.65.0",
    "babel-plugin-react-compiler": "^1.0.0",
    "eslint": "^10.7.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-no-unsanitized": "^4.1.5",
    "eslint-plugin-prettier": "^5.5.6",
    "eslint-plugin-react-doctor": "^0.8.3",
    "eslint-plugin-security": "^4.0.1",
    "eslint-plugin-unicorn": "^72.0.0",
    "markdownlint-cli": "^0.49.1",
    "prettier": "^3.9.6",
    "prettier-plugin-packagejson": "^3.0.2",
    "prettier-plugin-tailwindcss": "^0.8.1",
    "react-doctor": "^0.8.3",
    "stylelint": "^17.14.1",
    "stylelint-config-recess-order": "^7.7.0",
    "stylelint-config-standard": "^40.0.0",
    "stylelint-order": "^8.1.1",
    "tailwindcss": "^4.3.3",
    "tsx": "^4.23.1",
    "tw-animate-css": "^1.4.0",
    "typescript": "^7.0.2"
  },
  "packageManager": "bun@1.3.14",
  "trustedDependencies": [
    "unrs-resolver"
  ]
}
